import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);

        int[] A = new int[4];
        int[] B = new int[6];
        int[] C = new int[10];

        // leitura do vetor A
        System.out.println("Digite os 4 elementos do vetor A:");
        for (int i = 0; i < 4; i++) {
            System.out.print("A[" + i + "]: ");
            A[i] = entrada.nextInt();
        }

        // leitura do vetor B
        System.out.println("\nDigite os 6 elementos do vetor B:");
        for (int i = 0; i < 6; i++) {
            System.out.print("B[" + i + "]: ");
            B[i] = entrada.nextInt();
        }

        // colocar os elementos de A no vetor C
        for (int i = 0; i < 4; i++) {
            C[i] = A[i];
        }

        // colocar os elementos de B no vetor C, após os de A
        for (int i = 0; i < 6; i++) {
            C[4 + i] = B[i];
        }

        // mostrar o vetor C
        System.out.println("\nElementos do vetor C (A + B):");
        for (int i = 0; i < 10; i++) {
            System.out.print("C[" + i + "] = " + C[i] + "  ");
        }

        entrada.close();
    }
}
