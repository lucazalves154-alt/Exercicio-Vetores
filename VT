import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        Scanner entrada = new Scanner(System.in);

        String[] nomes = new String[5];

        // leitura dos 5 nomes
        for (int i = 0; i < 5; i++) {
            System.out.print("Digite o nome " + (i + 1) + ": ");
            nomes[i] = entrada.nextLine();
        }

        // (a) imprimir do último para o primeiro
        System.out.println("\n(a) Nomes do último para o primeiro:");
        for (int i = 4; i >= 0; i--) {
            System.out.println(nomes[i]);
        }

        System.out.println("\n(b) Primeiro e último nome:");
        System.out.println("Primeiro: " + nomes[0]);
        System.out.println("Último: "   + nomes[4]);

        entrada.close();
    }
}
